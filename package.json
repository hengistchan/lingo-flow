{
  "name": "lingoflow",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered bilingual web reading browser extension",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "browser-extension",
    "translation",
    "bilingual",
    "chrome-extension",
    "azure-translator",
    "openai",
    "bilingual-reading"
  ],
  "scripts": {
    "build": "pnpm --filter @lingoflow/extension build",
    "dev": "pnpm --filter @lingoflow/extension dev",
    "test": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "typecheck": "pnpm --filter @lingoflow/extension compile && tsc -p tsconfig.json --noEmit",
    "lint": "pnpm typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.326",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/compiler-sfc": "^3.5.16",
    "happy-dom": "^17.6.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3",
    "vue-tsc": "^2.2.10",
    "wxt": "^0.20.7"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "vue": "^3.5.16"
  }
}
